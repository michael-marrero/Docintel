# Build context exclusions for docker/Dockerfile.
# Keeps the build context small and prevents committed-secret leakage into images.

# Planning + version control
.planning/
.git/
.github/

# Secrets and runtime data
.env
.env.*
!.env.example
*.key
*.pem

# Build context: exclude `data/` wholesale, then re-include the tracked subdirs
# the Dockerfile selectively COPYs into the images (Phase 13 plan 13-08; see
# `docker/Dockerfile` comments). The negation overrides keep the gitignored
# runtime trees (`data/indices/`, `data/traces/`, `data/eval/cache/`) out of
# the build context while letting `COPY data/corpus/`, `COPY data/eval/...`
# resolve. Without these negations, COPY fails at build time with
# `"/data/...": not found` and the entrypoint never runs.
data/
!data/corpus/
!data/eval/
data/eval/cache/

# Python build / cache artifacts
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Test / tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# uv local cache (we use the in-image one)
.uv-cache/

# OS / editors
.DS_Store
.idea/
.vscode/
*.swp

# Tests do not ship in production images
tests/
**/tests/

# Documentation source
*.md
!README.md
