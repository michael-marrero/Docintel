.planning/

# Secrets / env files (Pitfall #26 — career-grade)
.env
.env.*
!.env.example
*.key
*.pem

# Project data (indices, traces — never committed; corpus partially committed per Phase 3 D-04 below)
# Phase 3 (D-04 + Pitfall 6): commit raw + normalized + chunks + MANIFEST + snapshot;
# ignore working cache.
data/corpus/.cache/
# Negation: previously data/corpus/ was wholesale ignored; now only .cache is.
!data/corpus/
!data/corpus/raw/
!data/corpus/raw/**
!data/corpus/normalized/
!data/corpus/normalized/**
!data/corpus/chunks/
!data/corpus/chunks/**
!data/corpus/MANIFEST.json
!data/corpus/companies.snapshot.csv
data/indices/
# data/indices/.qdrant/ is the docker-compose volume target for the Qdrant service (D-05); covered by the umbrella rule above.
data/traces/
data/eval/cache/

# Python build / packaging
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual envs / uv
.venv/
venv/
.uv-cache/
# uv.lock IS committed (deterministic builds)

# Test / tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

