# docintel — environment template
#
# Copy to `.env` and fill in real values (NEVER commit `.env`).
# Phase 1 only consumes DOCINTEL_LLM_PROVIDER. Other vars are
# pre-declared so future phases (Phase 2 adapters) don't surprise you.
#
# All vars are loaded by packages/docintel-core/src/docintel_core/config.py
# via pydantic-settings. That module is the ONLY place env vars are read.

# Provider flip (FND-08). Default everywhere — CI, docker-compose, local dev.
# stub = deterministic offline fixtures (no network, no keys).
# real = live Anthropic + OpenAI clients (requires the keys below).
DOCINTEL_LLM_PROVIDER=stub

# Which real LLM provider drives generation (ignored when DOCINTEL_LLM_PROVIDER=stub).
# The judge uses the complement provider — Anthropic generates, OpenAI judges, or vice versa (D-04).
# DOCINTEL_LLM_REAL_PROVIDER=anthropic

# Optional API keys — leave blank for stub mode.
# Phase 2 will start consuming these via the AdapterBundle factory.
DOCINTEL_ANTHROPIC_API_KEY=
DOCINTEL_OPENAI_API_KEY=

# --- OpenAI-compatible endpoint override (ADR-014 / D-14) -------------------
# Point the OpenAI adapter at any chat-completions-compatible gateway. Example
# below targets NVIDIA NIM's hosted catalog serving Llama-3.3-Nemotron-Super-49B,
# judged by Nemotron-3-Ultra-550B. The nvapi-... key goes in
# DOCINTEL_OPENAI_API_KEY above. Leave all three blank for real OpenAI / stub.
# (gpt-oss-120b was the original ADR-014 pick but its harmony/reasoning output
# carried no inline [chunk_id] citations the generator could parse — ANS-03.)
#
#   DOCINTEL_LLM_REAL_PROVIDER=openai
#   DOCINTEL_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
#   DOCINTEL_OPENAI_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
#   DOCINTEL_JUDGE_MODEL=nvidia/nemotron-3-ultra-550b-a55b
#
# When DOCINTEL_JUDGE_MODEL is set, the judge is a second OpenAI adapter on that
# model (distinct-MODEL cross-family). When blank, the v1.0 cross-PROVIDER judge
# applies (Anthropic judges OpenAI). Both models must be priced in pricing.py
# or cost_for() raises (ADR-006). Run scripts/nim_probe.py before a full eval.
# DOCINTEL_OPENAI_BASE_URL=
# DOCINTEL_OPENAI_MODEL=gpt-4o
# DOCINTEL_JUDGE_MODEL=

# Local data directory (corpus, indices, traces). Default is ./data.
DOCINTEL_DATA_DIR=data

# Git SHA — Docker injects this via ARG GIT_SHA. Locally defaults to "unknown".
DOCINTEL_GIT_SHA=unknown

# SEC EDGAR identifying User-Agent (Phase 3 — D-19).
# REQUIRED for `make fetch-corpus` against live sec.gov. Stub-mode CI never
# hits sec.gov so the CI-safe default in Settings is fine for tests.
# Format: "Your Name your.email@example.com".
DOCINTEL_EDGAR_USER_AGENT=

# Soft request rate for the SEC fetcher (sec-edgar-downloader enforces 10
# req/sec internally; this is a defensive headroom value).
DOCINTEL_EDGAR_REQUEST_RATE_HZ=8.0

# Qdrant HTTP endpoint (Phase 4 — D-17). Consumed ONLY when DOCINTEL_LLM_PROVIDER=real.
# Default targets the docker-compose service name in the 'real' compose profile.
# Stub-mode CI never reads this field (D-12 lazy-import discipline).
# DOCINTEL_QDRANT_URL=http://qdrant:6333

# Qdrant collection name for the dense index (Phase 4 — D-06). Default value
# matches the production-shaped naming; override only for ablation runs.
# DOCINTEL_QDRANT_COLLECTION=docintel-dense-v1
